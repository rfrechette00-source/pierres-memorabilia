{
  "version": 2,
  "crons": [
    {
      "path": "/api/monitor",
      "schedule": "7 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*\\.(jpg|jpeg|png|gif|JPG|JPEG|PNG))", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
